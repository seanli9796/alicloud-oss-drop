{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OSS Drop",
  "version": "1.0.1",
  "identifier": "com.ossdrop.desktop",
  "build": {
    "frontendDist": "../tauri-ui",
    "beforeDevCommand": "npm run sync:tauri-ui",
    "beforeBuildCommand": "npm run sync:tauri-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OSS Drop",
        "width": 1180,
        "height": 860,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
